# Required for Docker build (copy to .env.docker on server — not committed).
#   cp .env.docker.example .env.docker
#
# URL the browser uses to reach the API (public host + port or domain).
# Example EC2: http://3.112.xxx.xxx:8000/api
# Example HTTPS: https://yourdomain.com/api
VITE_API_BASE_URL=http://YOUR_PUBLIC_HOST:8000/api
